{
  "name": "recipe-app",
  "version": "1.0.0",
  "private": true,
  "description": "Recipe App - MERN Stack",
  "scripts": {
    "server": "cd server && npm start",
    "client": "cd client && npm start",
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"blue,green\" \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "start": "npm run server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
